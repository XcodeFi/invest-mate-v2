# Investment Mate v2 - Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local or any file with real secrets to git

# MongoDB
ConnectionStrings__MongoDb=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MongoDb__DatabaseName=investmentapp_prod

# JWT Authentication (use a strong random key, min 32 chars)
Jwt__Key=<your-strong-secret-key-min-32-chars>
Jwt__Issuer=InvestmentApp
Jwt__Audience=InvestmentAppUsers
Jwt__ExpiryInMinutes=60

# Google OAuth (from Google Cloud Console)
GoogleOAuth__ClientId=<your-google-client-id>.apps.googleusercontent.com
GoogleOAuth__ClientSecret=<your-google-client-secret>

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
