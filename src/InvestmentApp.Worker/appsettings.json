{
  "ConnectionStrings": {
    "MongoDb": "CHANGE_ME_USE_ENV_VAR_ConnectionStrings__MongoDb"
  },
  "MongoDb": {
    "DatabaseName": "CHANGE_ME_USE_ENV_VAR_MongoDb__DatabaseName"
  },
